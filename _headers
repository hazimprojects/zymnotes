# Cache-Control headers for Netlify / Cloudflare Pages
# GitHub Pages ignores this file, but it takes effect on migration.

# HTML — revalidate every visit (content changes often)
# Homepage root — always revalidate (important for social scrapers)
/
  Cache-Control: public, max-age=0, must-revalidate

/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Versioned CSS — immutable (query string ?v=X changes on update)
/assets/css/*
  Cache-Control: public, max-age=31536000, immutable

# Versioned JS — immutable
/assets/js/*
  Cache-Control: public, max-age=31536000, immutable

# Icons — long cache (change rarely)
/icons/*
  Cache-Control: public, max-age=604800

# Manifest — short cache (may change)
/manifest.json
  Cache-Control: public, max-age=86400

# Audio — long cache
/assets/audio/*
  Cache-Control: public, max-age=604800

# Data files — short cache
/data/*
  Cache-Control: public, max-age=3600

# Open Graph image — avoid stale social previews
/assets/og-image.png
  Cache-Control: public, max-age=0, no-cache, must-revalidate
