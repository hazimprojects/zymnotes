    {
      "source_id": "bab-7-2-u01",
      "bm_original": "💡 Jawatankuasa Hubungan Antara Kaum ditubuhkan kerana hubungan antara kaum selepas Perang Dunia Kedua semakin tegang, sedangkan kemerdekaan hanya boleh dicapai jika wujud kerjasama antara kaum utama di Tanah Melayu.",
      "zh_explain": "perang dunia kedua（第二次世界大战）；tanah melayu（马来亚）——此句是本节关键结论，理解这些词汇有助掌握核心论点。",
      "key_points_zh": [
        "perang dunia kedua = 第二次世界大战",
        "tanah melayu = 马来亚",
        "kemerdekaan = 独立",
        "kerjasama = 合作"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-7-2-u02",
      "bm_original": "📌 Oleh itu, perundingan antara pemimpin kaum dijalankan untuk membina kestabilan politik, memperbaiki ekonomi, mewujudkan keharmonian sosial dan menyediakan asas ke arah berkerajaan sendiri.",
      "zh_explain": "",
      "key_points_zh": [
        "rundingan = 谈判",
        "kerajaan = 政府",
        "pemimpin = 领导人",
        "ekonomi = 经济"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-7-2-u03",
      "bm_original": "📌 CLC menghimpunkan pemimpin utama pelbagai kaum di Tanah Melayu .",
