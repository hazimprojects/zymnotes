    {
      "source_id": "bab-4-5-u27",
      "bm_original": "Penyerahan Sarawak kepada British mencetuskan dua reaksi yang berbeza, iaitu golongan yang menentang dan golongan yang menyokong penyerahan.",
      "translate": "Penyerahan Sarawak 向 British mencetuskan dua reaksi 的 berbeza, iaitu golongan 的 反对 与 golongan 的 menyokong penyerahan.",
      "key_points_zh": [
        "Penyerahan Sarawak 向 British mencetuskan dua reaksi 的 berbeza, iaitu golongan 的 反对 与 golongan 的 menyokong penyerahan."
      ],
      "bm_focus_phrase": "Penyerahan Sarawak kepada British mencetuskan dua reaksi yang berbeza, iaitu golongan yang menentang dan golongan yang menyokong penyerahan."
    },
    {
      "source_id": "bab-4-5-u28",
      "bm_original": "Golongan yang menentang melihat penyerahan itu sebagai satu bentuk penjajahan baharu dan pelanggaran terhadap Perlembagaan 1941 .",
      "translate": "Golongan 的 反对 melihat penyerahan 那 作为 satu bentuk penjajahan baharu 与 pelanggaran 针对 Perlembagaan 1941 .",
      "key_points_zh": [
        "Golongan 的 反对 melihat penyerahan 那 作为 satu bentuk penjajahan baharu 与 pelanggaran 针对 Perlembagaan 1941 ."
      ],
      "bm_focus_phrase": "Golongan yang menentang melihat penyerahan itu sebagai satu bentuk penjajahan baharu dan pelanggaran terhadap Perlembagaan 1941 ."
    },
    {
      "source_id": "bab-4-5-u29",
      "bm_original": "Gerakan antipenyerahan menggunakan persidangan, demonstrasi, peletakan jawatan, akhbar, surat bantahan dan penubuhan Rukun 13 .",
      "translate": "Gerakan antipenyerahan menggunakan persidangan, demonstrasi, peletakan jawatan, 报章, surat 抗议 与 成立 Rukun 13 .",
      "key_points_zh": [
        "Gerakan antipenyerahan menggunakan persidangan, demonstrasi, peletakan jawatan, 报章, surat 抗议 与 成立 Rukun 13 ."
      ],
      "bm_focus_phrase": "Gerakan antipenyerahan menggunakan persidangan, demonstrasi, peletakan jawatan, akhbar, surat bantahan dan penubuhan Rukun 13 ."
    },
    {
      "source_id": "bab-4-5-u30",
      "bm_original": "Golongan yang menyokong pula percaya British dapat memajukan negeri, meningkatkan taraf hidup rakyat dan membuka peluang pekerjaan.",
