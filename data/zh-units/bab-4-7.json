  "units": [
    {
      "source_id": "bab-4-7-u01",
      "bm_original": "💡 Penyerahan Sabah kepada British pada 15 Julai 1946 tidak mendapat penentangan besar daripada penduduk tempatan kerana British berjaya melemahkan kegiatan berpersatuan, mengehadkan peluang penduduk dalam pentadbiran, dan pada masa yang sama ramai penduduk melihat penyerahan itu sebagai peluang untu",
      "zh_explain": "pentadbiran（行政）；penentangan（抵抗）——此句是本节关键结论，理解这些词汇有助掌握核心论点。",
      "key_points_zh": [
        "pentadbiran = 行政",
        "penentangan = 抵抗",
        "british = 英国",
        "sabah = 沙巴"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-4-7-u02",
      "bm_original": "💡 Keadaan ini menyukarkan pemimpin tempatan untuk menyatukan semua etnik dalam satu pertubuhan yang kuat.",
      "zh_explain": "pertubuhan（组织）；pemimpin（领导人）——此句是本节关键结论，理解这些词汇有助掌握核心论点。",
      "key_points_zh": [
        "pertubuhan = 组织",
        "pemimpin = 领导人"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-4-7-u03",
      "bm_original": "💡 Tindakan British ini berjaya melemahkan pengaruh pemimpin tempatan secara beransur-ansur.",
      "zh_explain": "pengaruh（影响）；pemimpin（领导人）——此句是本节关键结论，理解这些词汇有助掌握核心论点。",
      "key_points_zh": [
        "pengaruh = 影响",
        "pemimpin = 领导人",
        "british = 英国"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-4-7-u04",
      "bm_original": "💡 Keadaan ini menyebabkan gerakan kebangsaan di Sabah berkembang dengan lebih perlahan.",
      "zh_explain": "bangsa（民族）；sabah（沙巴）——此句是本节关键结论，理解这些词汇有助掌握核心论点。",
      "key_points_zh": [
        "bangsa = 民族",
        "sabah = 沙巴"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-4-7-u05",
      "bm_original": "💡 Reaksi ini menunjukkan bahawa pertimbangan ekonomi dan kehidupan harian sangat mempengaruhi sikap masyarakat tempatan ketika itu.",
      "zh_explain": "pengaruh（影响）；ekonomi（经济）——此句是本节关键结论，理解这些词汇有助掌握核心论点。",
      "key_points_zh": [
        "pengaruh = 影响",
        "ekonomi = 经济"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-4-7-u06",
      "bm_original": "💡 Namun begitu, pengalaman di bawah pemerintahan British tetap menanam kesedaran politik dalam kalangan penduduk tempatan.",
      "zh_explain": "pemerintahan（统治）；kesedaran（意识）——此句是本节关键结论，理解这些词汇有助掌握核心论点。",
      "key_points_zh": [
        "pemerintahan = 统治",
        "kesedaran = 意识",
        "british = 英国"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-4-7-u07",
      "bm_original": "🇬🇧 Penyerahan Sabah kepada British pada 15 Julai 1946 tidak mendapat penentangan besar daripada penduduk tempatan.",
      "zh_explain": "penentangan（抵抗）；british（英国）",
      "key_points_zh": [
        "penentangan = 抵抗",
        "british = 英国",
        "sabah = 沙巴"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-4-7-u08",
      "bm_original": "⚠️ Hal ini berlaku kerana British berjaya melemahkan gerakan berpersatuan dan mengehadkan peluang penduduk tempatan dalam pentadbiran.",
      "zh_explain": "pentadbiran（行政）；british（英国）",
      "key_points_zh": [
        "pentadbiran = 行政",
        "british = 英国"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-4-7-u09",
      "bm_original": "💼 Pada masa yang sama, ramai penduduk melihat penyerahan itu sebagai peluang untuk memajukan kehidupan dan membangunkan semula Sabah selepas perang.",
      "zh_explain": "perang（战争）；sabah（沙巴）",
      "key_points_zh": [
        "perang = 战争",
        "sabah = 沙巴"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-4-7-u10",
      "bm_original": "🇲🇾 Walaupun kebangkitan nasionalisme di Sabah berkembang lebih perlahan, pengalaman di bawah British tetap menanam kesedaran politik dalam kalangan penduduk tempatan.",
      "zh_explain": "nasionalisme（民族主义）；kesedaran（意识）",
      "key_points_zh": [
        "nasionalisme = 民族主义",
        "kesedaran = 意识",
        "british = 英国",
        "sabah = 沙巴"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-4-7-u11",
      "bm_original": "📌 Dasar British selepas Perang Dunia Kedua di Tanah Melayu , Sarawak dan Sabah telah mencetuskan reaksi yang berbeza dalam kalangan penduduk tempatan.",
      "zh_explain": "",
      "key_points_zh": [
        "perang dunia kedua = 第二次世界大战",
        "tanah melayu = 马来亚",
        "british = 英国",
        "sarawak = 砂拉越"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-4-7-u12",
      "bm_original": "🇲🇾 Di Tanah Melayu, orang Melayu bangkit menentang Malayan Union secara besar-besaran hingga gagasan itu gagal dilaksanakan.",
      "zh_explain": "malayan union（马来亚联盟）；tanah melayu（马来亚）",
      "key_points_zh": [
        "malayan union = 马来亚联盟",
        "tanah melayu = 马来亚",
        "orang melayu = 马来人",
        "melayu = 马来"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-4-7-u13",
      "bm_original": "🌳 Di Sarawak, penyerahan kepada British mencetuskan gerakan antipenyerahan yang kuat walaupun akhirnya tidak berjaya.",
      "zh_explain": "british（英国）；sarawak（砂拉越）",
      "key_points_zh": [
        "british = 英国",
        "sarawak = 砂拉越"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-4-7-u14",
      "bm_original": "🏝️ Di Sabah, penyerahan kepada British tidak mendapat tentangan terbuka yang besar kerana British berjaya melemahkan gerakan berpersatuan dan ramai penduduk lebih menumpukan kepentingan sosioekonomi.",
      "zh_explain": "british（英国）；ekonomi（经济）",
      "key_points_zh": [
        "british = 英国",
        "ekonomi = 经济",
        "sabah = 沙巴"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-4-7-u15",
      "bm_original": "💡 Walaupun reaksi di ketiga-tiga wilayah berbeza, dasar British selepas perang telah menyemarakkan kebangkitan nasionalisme dan meningkatkan kesedaran rakyat untuk membebaskan tanah air daripada penjajahan.",
      "zh_explain": "nasionalisme（民族主义）；penjajahan（殖民统治）——此句是本节关键结论，理解这些词汇有助掌握核心论点。",
      "key_points_zh": [
        "nasionalisme = 民族主义",
        "penjajahan = 殖民统治",
        "kesedaran = 意识",
        "penjajah = 殖民者"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-4-7-u16",
      "bm_original": "🚩 Perkembangan ini menjadi asas penting kepada perjuangan ke arah kemerdekaan negara pada peringkat seterusnya.",
      "zh_explain": "perkembangan（发展）；kemerdekaan（独立）",
      "key_points_zh": [
        "perkembangan = 发展",
        "kemerdekaan = 独立",
        "perjuangan = 斗争"
      ],
      "bm_focus_phrase": ""
    },
    {
