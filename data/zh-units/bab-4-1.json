    {
      "source_id": "bab-4-1-u13",
      "bm_original": "🪖 British Military Administration (BMA) ialah pentadbiran tentera British di Tanah Melayu yang bermula pada 12 September 1945 .",
      "zh_explain": "tanah melayu（马来亚）；pentadbiran（行政）",
      "key_points_zh": [
        "tanah melayu = 马来亚",
