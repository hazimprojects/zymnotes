      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-3-5-u08",
      "bm_original": "📌 Kedua-dua faktor ini saling berkait dalam usaha Jepun meluaskan kuasa di Asia dan mengukuhkan ekonominya.",
