    {
      "source_id": "bab-1-2-soalan-heading",
      "bm_original": "Apakah ciri-ciri negara bangsa yang terdapat dalam Kesultanan Melayu Melaka?",
      "zh_explain": "这道问题引导学生先判断核心概念，再说明历史根据。",
      "key_points_zh": [
        "先锁定题目关键词。",
        "回答时要有立场与证据。"
      ],
      "bm_focus_phrase": "Apakah ciri-ciri negara bangsa yang terdapat dalam Kesultanan Melayu Melaka?"
    },
    {
      "source_id": "bab-1-2-soalan-line-1",
      "bm_original": "💡 Kesultanan Melayu Melaka mempunyai sistem pemerintahan yang tersusun dan lengkap, yang menunjukkan pembentukan negara bangsa yang kukuh sebelum kedatangan Barat.",
      "zh_explain": "这句是对主问题的核心答案，概括本小节最重要的因果与结论。",
      "key_points_zh": [
        "抓住主语、动作与结果。",
        "可用一句话复述大意。"
      ],
      "bm_focus_phrase": "💡 Kesultanan Melayu Melaka mempunyai sistem pemerintahan yang tersusun dan lengkap, yang menunjukkan pembentukan negara bangsa yang kukuh sebelum kedatangan Barat."
    },
    {
      "source_id": "bab-1-2-fokus-line",
      "bm_original": "Kesultanan Melayu Melaka merupakan contoh pembentukan negara bangsa yang kukuh di Alam Melayu. Subtopik ini menghuraikan ciri-ciri utama yang membuktikan Melaka sebagai sebuah negara bangsa yang berdaulat:",
      "zh_explain": "这句说明本课范围与学习路线，帮助学生建立章节地图。",
      "key_points_zh": [
        "先看本节讨论范围。",
        "记住将要展开的重点项目。"
      ],
      "bm_focus_phrase": "Subtopik ini membincangkan"
    },
    {
      "source_id": "bab-1-2-u01",
      "bm_original": "💡 Sistem pentadbiran yang teratur menjadikan Melaka sebagai empayar yang terkenal.",
      "zh_explain": "pentadbiran（行政）；melaka（马六甲）——此句是本节关键结论，理解这些词汇有助掌握核心论点。",
      "key_points_zh": [
        "pentadbiran = 行政",
        "melaka = 马六甲",
        "sistem = 制度"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-1-2-u02",
      "bm_original": "💡 Hubungan timbal balik ini mewujudkan persefahaman dan kestabilan politik.",
      "zh_explain": "persefahaman（相互理解）——此句是本节关键结论，理解这些词汇有助掌握核心论点。",
      "key_points_zh": [
        "persefahaman = 相互理解"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-1-2-u03",
      "bm_original": "💡 Hubungan ini mengukuhkan kedudukan Melaka sebagai kerajaan berdaulat.",
      "zh_explain": "berdaulat（具主权的）；kerajaan（政府）——此句是本节关键结论，理解这些词汇有助掌握核心论点。",
      "key_points_zh": [
        "berdaulat = 具主权的",
        "kerajaan = 政府",
        "melaka = 马六甲",
        "raja = 国王"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-1-2-u04",
      "bm_original": "💡 Wilayah yang luas membuktikan kewibawaan pemerintah.",
      "zh_explain": "wilayah（领土）——此句是本节关键结论，理解这些词汇有助掌握核心论点。",
      "key_points_zh": [
        "wilayah = 领土"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-1-2-u05",
      "bm_original": "📌 Diperoleh melalui peperangan.",
      "zh_explain": "",
      "key_points_zh": [
        "peperangan = 战争"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-1-2-u06",
      "bm_original": "📌 Menerima ketuanan Melaka melalui perkahwinan atau persahabatan.",
      "zh_explain": "",
      "key_points_zh": [
        "perkahwinan = 婚姻",
        "menerima = 接受",
        "melaka = 马六甲",
        "ketua = 首领"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-1-2-u07",
      "bm_original": "📌 Contoh: Kerajaan Majapahit menghadiahkan Siantan kepada Sultan Mansur Shah kerana perkahwinan diraja.",
