    {
      "source_id": "bab-4-6-u01",
      "bm_original": "💡 Selepas Perang Dunia Kedua , Sabah diserahkan kepada kerajaan British dan dijadikan tanah jajahan British. Penyerahan ini berlaku kerana kepentingan British, dasar hubungan luar yang sudah dikuasai British, serta masalah kewangan yang dihadapi oleh Syarikat Borneo Utara British (SBUB) .",
      "zh_explain": "perang dunia kedua（第二次世界大战）；kerajaan（政府）——此句是本节关键结论，理解这些词汇有助掌握核心论点。",
      "key_points_zh": [
        "perang dunia kedua = 第二次世界大战",
        "kerajaan = 政府",
        "kewangan = 财政",
        "british = 英国"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-4-6-u02",
      "bm_original": "💡 Tugas utama BMA ialah mengembalikan keamanan dan ketenteraman di Sabah.",
      "zh_explain": "sabah（沙巴）——此句是本节关键结论，理解这些词汇有助掌握核心论点。",
      "key_points_zh": [
        "sabah = 沙巴"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-4-6-u03",
      "bm_original": "📌 Sabah penting kepada British kerana:",
      "zh_explain": "",
      "key_points_zh": [
        "british = 英国",
        "sabah = 沙巴"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-4-6-u04",
      "bm_original": "💡 Oleh itu, British mahu terus menguasai Sabah untuk menjaga kepentingan ekonominya.",
      "zh_explain": "british（英国）；ekonomi（经济）——此句是本节关键结论，理解这些词汇有助掌握核心论点。",
      "key_points_zh": [
        "british = 英国",
        "ekonomi = 经济",
        "sabah = 沙巴"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-4-6-u05",
      "bm_original": "💡 Keadaan ini menyebabkan SBUB lebih mudah membuat keputusan untuk menyerahkan Sabah kepada kerajaan British pada tahun 1946.",
      "zh_explain": "kerajaan（政府）；british（英国）——此句是本节关键结论，理解这些词汇有助掌握核心论点。",
      "key_points_zh": [
        "kerajaan = 政府",
        "british = 英国",
        "sabah = 沙巴",
        "raja = 国王"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-4-6-u06",
      "bm_original": "💡 Penyerahan ini juga menunjukkan bahawa pengaruh British di Sabah sudah lama wujud sebelum Sabah dijadikan tanah jajahan secara rasmi.",
      "zh_explain": "pengaruh（影响）；british（英国）——此句是本节关键结论，理解这些词汇有助掌握核心论点。",
      "key_points_zh": [
        "pengaruh = 影响",
        "british = 英国",
        "jajahan = 殖民地",
        "sabah = 沙巴"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-4-6-u07",
      "bm_original": "📌 Antaranya melibatkan pembaikan:",
