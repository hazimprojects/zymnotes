    {
      "source_id": "bab-1-3-u48",
      "bm_original": "Kesultanan Melayu Melaka membuktikan keunggulannya melalui sistem pentadbiran yang tersusun.",
      "translate": "Kesultanan Melayu Melaka membuktikan keunggulannya 通过 sistem 行政 的 tersusun.",
      "key_points_zh": [
        "Kesultanan Melayu Melaka membuktikan keunggulannya 通过 sistem 行政 的 tersusun."
      ],
      "bm_focus_phrase": "Kesultanan Melayu Melaka membuktikan keunggulannya melalui sistem pentadbiran yang tersusun."
    },
    {
      "source_id": "bab-1-3-u49",
      "bm_original": "Keunggulan turut terserlah melalui undang-undang yang teratur dan sistematik.",
      "translate": "Keunggulan turut terserlah 通过 undang-undang 的 teratur 与 sistematik.",
      "key_points_zh": [
        "Keunggulan turut terserlah 通过 undang-undang 的 teratur 与 sistematik."
      ],
      "bm_focus_phrase": "Keunggulan turut terserlah melalui undang-undang yang teratur dan sistematik."
    },
    {
      "source_id": "bab-1-3-u50",
      "bm_original": "Kerjasama antara sultan dan para pembesar menjadikan pentadbiran berjalan lancar.",
      "translate": "Kerjasama 其中 sultan 与 para pembesar menjadikan 行政 berjalan lancar.",
      "key_points_zh": [
        "Kerjasama 其中 sultan 与 para pembesar menjadikan 行政 berjalan lancar."
      ],
      "bm_focus_phrase": "Kerjasama antara sultan dan para pembesar menjadikan pentadbiran berjalan lancar."
    },
    {
      "source_id": "bab-1-3-u51",
      "bm_original": "Keunggulan ini menjadikan Melaka sebagai kerajaan yang masyhur dan unggul.",
      "translate": "Keunggulan 这 menjadikan Melaka 作为 政府 的 masyhur 与 unggul.",
      "key_points_zh": [
        "Keunggulan 这 menjadikan Melaka 作为 政府 的 masyhur 与 unggul."
      ],
      "bm_focus_phrase": "Keunggulan ini menjadikan Melaka sebagai kerajaan yang masyhur dan unggul."
    },
    {
      "source_id": "bab-1-3-soalan-heading",
      "bm_original": "Apakah yang dimaksudkan dengan keunggulan dalam sesebuah kerajaan?",
      "translate": "Apakah 的 dimaksudkan 以 keunggulan 在 sesebuah 政府?",
      "key_points_zh": [
        "Apakah 的 dimaksudkan 以 keunggulan 在 sesebuah 政府?"
      ],
      "bm_focus_phrase": "Apakah yang dimaksudkan dengan keunggulan dalam sesebuah kerajaan?"
    },
    {
      "source_id": "bab-1-3-soalan-line-1",
      "bm_original": "Keunggulan bermaksud kesempurnaan dan keistimewaan yang dimiliki oleh sesebuah kerajaan.",
      "translate": "Keunggulan bermaksud kesempurnaan 与 keistimewaan 的 dimiliki 由 sesebuah 政府.",
      "key_points_zh": [
        "Keunggulan bermaksud kesempurnaan 与 keistimewaan 的 dimiliki 由 sesebuah 政府."
      ],
      "bm_focus_phrase": "Keunggulan bermaksud kesempurnaan dan keistimewaan yang dimiliki oleh sesebuah kerajaan."
    },
    {
      "source_id": "bab-1-3-u01",
      "bm_original": "Dalam Kesultanan Melayu Melaka , keunggulan ini dapat dilihat dengan jelas melalui sistem pentadbiran yang tersusun dan undang-undang yang teratur.",
      "translate": "Dalam Kesultanan Melayu Melaka , keunggulan 这 dapat dilihat 以 jelas 通过 sistem 行政 的 tersusun 与 undang-undang 的 teratur.",
      "key_points_zh": [
        "Dalam Kesultanan Melayu Melaka , keunggulan 这 dapat dilihat 以 jelas 通过 sistem 行政 的 tersusun 与 undang-undang 的 teratur."
      ],
      "bm_focus_phrase": "Dalam Kesultanan Melayu Melaka , keunggulan ini dapat dilihat dengan jelas melalui sistem pentadbiran yang tersusun dan undang-undang yang teratur."
    },
    {
      "source_id": "bab-1-3-fokus-line",
      "bm_original": "Kesultanan Melayu Melaka mempunyai sistem pentadbiran dan undang-undang yang tersusun dan sistematik. Subtopik ini membincangkan dua aspek keunggulan Melaka:",
