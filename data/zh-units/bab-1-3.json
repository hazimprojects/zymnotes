  "units": [
    {
      "source_id": "bab-1-3-u48",
      "bm_original": "Kesultanan Melayu Melaka membuktikan keunggulannya melalui sistem pentadbiran yang tersusun.",
      "translate": "Kesultanan Melayu Melaka 通过有序的行政制度展现了它的卓越。"
    },
    {
      "source_id": "bab-1-3-u49",
      "bm_original": "Keunggulan turut terserlah melalui undang-undang yang teratur dan sistematik.",
      "translate": "这种卓越也体现在完善而系统化的法律制度上。"
    },
    {
      "source_id": "bab-1-3-u50",
      "bm_original": "Kerjasama antara sultan dan para pembesar menjadikan pentadbiran berjalan lancar.",
      "translate": "苏丹与诸位贵族之间的合作，使行政运作顺利进行。"
    },
    {
      "source_id": "bab-1-3-u51",
      "bm_original": "Keunggulan ini menjadikan Melaka sebagai kerajaan yang masyhur dan unggul.",
      "translate": "这种卓越使 Melaka 成为一个著名而杰出的王国。"
    },
    {
      "source_id": "bab-1-3-soalan-heading",
      "bm_original": "Apakah yang dimaksudkan dengan keunggulan dalam sesebuah kerajaan?",
      "translate": "一个王国的“卓越”指的是什么？"
    },
    {
      "source_id": "bab-1-3-soalan-line-1",
      "bm_original": "Keunggulan bermaksud kesempurnaan dan keistimewaan yang dimiliki oleh sesebuah kerajaan.",
      "translate": "“卓越”是指一个王国所拥有的完善性与独特优势。"
    },
    {
      "source_id": "bab-1-3-u01",
      "bm_original": "Dalam Kesultanan Melayu Melaka, keunggulan ini dapat dilihat dengan jelas melalui sistem pentadbiran yang tersusun dan undang-undang yang teratur.",
      "translate": "在 Kesultanan Melayu Melaka，这种卓越清楚体现在有序的行政制度和完善的法律体系上。"
    },
    {
      "source_id": "bab-1-3-fokus-line",
      "bm_original": "Kesultanan Melayu Melaka mempunyai sistem pentadbiran dan undang-undang yang tersusun dan sistematik. Subtopik ini membincangkan dua aspek keunggulan Melaka:",
      "translate": "Kesultanan Melayu Melaka 拥有有序而系统化的行政与法律制度。本小节将讨论 Melaka 卓越性的两个方面："
    },
    {
      "source_id": "bab-1-3-u02a",
      "bm_original": "Kesultanan Melayu Melaka mempunyai sistem pentadbiran yang lengkap, tersusun dan sistematik.",
      "translate": "Kesultanan Melayu Melaka 拥有完整、有序且系统化的行政制度。"
    },
    {
      "source_id": "bab-1-3-u02b",
      "bm_original": "Sistem ini dikenali sebagai Sistem Pembesar Empat Lipatan.",
      "translate": "这个制度称为 Sistem Pembesar Empat Lipatan（四层级大臣制度）。"
    },
    {
      "source_id": "bab-1-3-u02",
      "bm_original": "Sistem ini memastikan pentadbiran berjalan lancar dan teratur.",
      "translate": "这个制度确保行政顺利且有条理地运作。"
    },
    {
      "source_id": "bab-1-3-u03",
      "bm_original": "Sistem pentadbiran Melaka bersifat:",
      "translate": "Melaka 的行政制度具有以下特点："
    },
