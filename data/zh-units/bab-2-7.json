        "tujuan = 目的",
        "china = 中国"
      ],
      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-2-7-u13",
      "bm_original": "📌 Karya kreatif seperti novel, puisi dan cerpen turut menyemai semangat nasionalisme.",
