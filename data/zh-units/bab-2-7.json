      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-2-7-u20",
      "bm_original": "🖋️ Penulisan melalui akhbar, majalah dan karya kreatif menyebarkan idea nasionalisme kepada masyarakat.",
      "zh_explain": "nasionalisme（民族主义）；penulisan（著述）",
      "key_points_zh": [
