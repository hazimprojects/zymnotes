      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-2-7-u21",
      "bm_original": "🤝 Persatuan dan pertubuhan pula menyatukan suara rakyat untuk menuntut hak serta membina jati diri bangsa.",
      "zh_explain": "pertubuhan（组织）；bangsa（民族）",
