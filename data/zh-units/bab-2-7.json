      "bm_focus_phrase": ""
    },
    {
      "source_id": "bab-2-7-u19",
      "bm_original": "🎓 Golongan intelektual berpendidikan agama, Inggeris dan Melayu menjadi pelopor kesedaran nasionalisme.",
      "zh_explain": "nasionalisme（民族主义）；pendidikan（教育）",
