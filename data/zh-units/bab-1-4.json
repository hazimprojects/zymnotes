  "units": [
    {
      "source_id": "bab-1-4-u17",
      "bm_original": "Hubungan antara pemerintah dan rakyat berasaskan konsep waadat.",
      "translate": "统治者与人民之间的关系是建立在 waadat 这个概念之上的。"
    },
    {
      "source_id": "bab-1-4-u18",
      "bm_original": "Hubungan ini bersifat timbal balik dan saling melengkapi.",
      "translate": "这种关系具有相互回馈、彼此补充的性质。"
    },
    {
      "source_id": "bab-1-4-u19",
      "bm_original": "Hubungan ini menyokong sistem pemerintahan dalam Kesultanan Melayu Melaka.",
      "translate": "这种关系支撑了 Kesultanan Melayu Melaka 的统治体系。"
    },
    {
      "source_id": "bab-1-4-u20",
      "bm_original": "Hasilnya, pentadbiran berjalan lancar dan Melaka mencapai kegemilangan.",
      "translate": "结果，行政运作顺利，Melaka 也因此达到辉煌。"
    },
    {
      "source_id": "bab-1-4-soalan-heading",
      "bm_original": "Bagaimanakah hubungan antara pemerintah dan rakyat dalam Kesultanan Melayu Melaka?",
      "translate": "在 Kesultanan Melayu Melaka，统治者与人民之间的关系是怎样的？"
    },
    {
      "source_id": "bab-1-4-soalan-line-1",
      "bm_original": "Hubungan antara pemerintah dan rakyat dalam Kesultanan Melayu Melaka berasaskan konsep waadat, iaitu perjanjian antara pemerintah dan rakyat.",
      "translate": "在 Kesultanan Melayu Melaka，统治者与人民之间的关系建立在 waadat 之上，也就是统治者与人民之间的一种约定。"
    },
    {
      "source_id": "bab-1-4-u01",
      "bm_original": "Hubungan ini bersifat timbal balik dan saling melengkapi, lalu menyokong kestabilan pemerintahan.",
      "translate": "这种关系具有相互回馈、彼此补充的特点，从而支撑统治的稳定。"
    },
    {
      "source_id": "bab-1-4-u02",
      "bm_original": "Hasilnya, pentadbiran berjalan lancar dan Kesultanan Melayu Melaka mencapai kegemilangan.",
      "translate": "结果，行政运作顺利，Kesultanan Melayu Melaka 因而达到辉煌。"
    },
    {
      "source_id": "bab-1-4-fokus-line",
      "bm_original": "Dalam Kesultanan Melayu Melaka, hubungan antara pemerintah dan rakyat didasari oleh konsep waadat yang bersifat timbal balik dan saling melengkapi. Subtopik ini menjelaskan struktur masyarakat dan jenis-jenis hubungan yang wujud:",
      "translate": "在 Kesultanan Melayu Melaka，统治者与人民之间的关系以 waadat 为基础，具有相互回馈与彼此补充的性质。本小节将说明社会结构以及所存在的关系类型："
    },
    {
      "source_id": "bab-1-4-u03",
      "bm_original": "Masyarakat Melaka terbahagi kepada dua:",
      "translate": "Melaka 社会分为两大部分："
    },
    {
      "source_id": "bab-1-4-extra-1",
      "bm_original": "1️⃣ Golongan Pemerintah 👑",
      "translate": "1️⃣ 统治阶层 👑"
    },
    {
      "source_id": "bab-1-4-extra-2",
      "bm_original": "2️⃣ Golongan Diperintah 👥",
      "translate": "2️⃣ 被统治阶层 👥"
    },
    {
      "source_id": "bab-1-4-u04",
      "bm_original": "Terdiri daripada:",
      "translate": "释义：包括：（原文：Terdiri daripada:）"
    },
